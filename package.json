{
  "name": "spelltable-pro",
  "version": "1.0.0",
  "description": "Modern, AI-powered TCG table replacement for Magic: The Gathering",
  "main": "api/server.js",
  "scripts": {
    "start": "node api/server.js",
    "start:detect": "node api/detect-server.js",
    "dev": "nodemon api/server.js",
    "dev:detect": "nodemon api/detect-server.js",
    "build:phash": "node scripts/build-phash-db.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint \"api/**/*.js\" \"scripts/**/*.js\" \"js/**/*.js\"",
    "build": "npm run lint && npm test",
    "deploy": "vercel deploy"
  },
  "keywords": [
    "magic-the-gathering",
    "tcg",
    "table",
    "game",
    "webRTC",
    "ai"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "image-hash": "^7.0.1",
    "mongoose": "^8.0.3",
    "multer": "^2.0.1",
    "sharp": "^0.33.2",
    "socket.io": "^4.6.0",
    "tesseract.js": "^5.0.4",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": [
      "api/routes/detect.js",
      "api/routes/cards.js",
      "api/services/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 75,
        "branches": 60,
        "functions": 70,
        "statements": 75
      }
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/spelltable-pro.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/spelltable-pro/issues"
  },
  "homepage": "https://github.com/yourusername/spelltable-pro#readme"
}
