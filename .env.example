# SpellTable Pro+ — Environment Variables
# Copy to `.env` and fill in. See DEPLOY-SPLIT.md for which vars go where.

# ─── Shared ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000

# ─── Main server (games / cards / auth) — Vercel in prod ───────────────
MONGODB_URI=mongodb://localhost:27017/spelltable-pro
# If you don't want to run MongoDB locally, set MOCK_DATA=true.
MOCK_DATA=false
JWT_SECRET=replace-me-with-a-long-random-string

# Vercel deploys set this automatically so /api/detect returns 501.
# Locally: leave unset so detection mounts on the main server.
# SKIP_DETECT=true

# ─── Detection service — Railway in prod (api/detect-server.js) ───────
DETECT_PORT=4000
# Pre-downloaded Tesseract model dir. Baked into Dockerfile.detect;
# unset for local dev (tesseract.js will fetch on first call).
# TESSDATA_DIR=/app/tessdata

# ─── Optional observability ────────────────────────────────────────────
# SENTRY_DSN=
# ANALYTICS_ID=
